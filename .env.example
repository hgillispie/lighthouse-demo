# Required — AI engine for agent chat and briefing generation
# Configure your LLM provider via the Setup tab in the agent sidebar
# LLM_API_KEY=your-api-key-here

# Optional — post high-severity signals to a Slack channel
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional — route outbound scraping through a proxy to avoid rate limits
# SCRAPE_PROXY_URL=https://proxy.example.com
