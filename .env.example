# Required — AI engine for agent chat and briefing generation
# Get a key at https://console.anthropic.com or connect via Builder.io OAuth
# ANTHROPIC_API_KEY=sk-ant-...

# Optional — seed sample competitors on first boot (set to "true" to enable)
# SEED_DEMO_DATA=true

# Optional — post high-severity signals to a Slack channel
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional — route outbound scraping through a proxy to avoid rate limits
# SCRAPE_PROXY_URL=https://proxy.example.com
